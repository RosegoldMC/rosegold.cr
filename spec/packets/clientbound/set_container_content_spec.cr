require "../../spec_helper"

Spectator.describe Rosegold::Clientbound::SetContainerContent do
  it "uses correct packet ID for protocol 772" do
    expect(Rosegold::Clientbound::SetContainerContent[772_u32]).to eq(0x12_u32)
  end

  it "supports protocol 772 only" do
    expect(Rosegold::Clientbound::SetContainerContent.supports_protocol?(772_u32)).to be_true
    expect(Rosegold::Clientbound::SetContainerContent.supports_protocol?(999_u32)).to be_false
  end

  describe "1.21.8" do
    before_each { Rosegold::Client.protocol_version = 772_u32 }
    after_each { Rosegold::Client.reset_protocol_version! }

    let(:packet_bytes) { Bytes.new(failing_packet_hex.size // 2) { |i| failing_packet_hex[i * 2, 2].to_u8(16) } }
    let(:io) { Minecraft::IO::Memory.new(packet_bytes) }

    describe "1" do
      let(:failing_packet_hex) { "" }

      it "is able to read" do
        io.read_byte # Skip packet ID (0x12)

        expect { Rosegold::Clientbound::SetContainerContent.read(io) }.not_to raise_error
      end

      it "contains the right container data" do
        io.read_byte # Skip packet ID (0x12)
        container = Rosegold::Clientbound::SetContainerContent.read(io)

        expect(container.window_id).to eq(0_u8)
        expect(container.state_id).to eq(46_u32)
        # Packet is truncated, so we expect fewer slots than the declared 46
        expect(container.slots.size).to eq(46)
      end
    end

    describe "includes banner_patterns data (63)" do
      let(:failing_packet_hex) { "" }

      it "is able to read" do
        io.read_byte # Skip packet ID (0x12)
        expect { Rosegold::Clientbound::SetContainerContent.read(io) }.not_to raise_error
      end
    end

    describe "potion data (42)" do
      let(:failing_packet_hex) { "" }

      it "is able to read" do
        io.read_byte # Skip packet ID (0x12)
        expect { Rosegold::Clientbound::SetContainerContent.read(io) }.not_to raise_error
      end
    end

    describe "includes trim data (47)" do
      let(:failing_packet_hex) { "" }

      it "is able to read" do
        io.read_byte # Skip packet ID (0x12)
        # Should not raise "Unknown data component type: 47" error specifically
        # Other parsing errors may still occur due to complex packet structure
        expect { Rosegold::Clientbound::SetContainerContent.read(io) }.not_to raise_error(Exception, /Unknown data component type: 47/)
      end
    end

    describe "includes dyed_color data component type 35" do
      let(:failing_packet_hex) { "" }

      it "is able to read" do
        io.read_byte # Skip packet ID (0x12)
        expect { Rosegold::Clientbound::SetContainerContent.read(io) }.not_to raise_error
      end
    end
  end

  describe "1.21.11" do
    before_each { Rosegold::Client.protocol_version = 774_u32 }
    after_each { Rosegold::Client.reset_protocol_version! }

    let(:packet_bytes) { Bytes.new(failing_packet_hex.size // 2) { |i| failing_packet_hex[i * 2, 2].to_u8(16) } }
    let(:io) { Minecraft::IO::Memory.new(packet_bytes) }

    describe "real production packet with many slots" do
      let(:failing_packet_hex) { "" }

      it "does not raise" do
        io.read_byte # Skip packet ID (0x12)
        expect { Rosegold::Clientbound::SetContainerContent.read(io) }.not_to raise_error
      end

      it "parses window_id, state_id, and slot count" do
        io.read_byte # Skip packet ID (0x12)
        container = Rosegold::Clientbound::SetContainerContent.read(io)

        # Bytes after packet ID: 02=window_id, 01=state_id, 5a=num_slots(90)
        expect(container.window_id).to eq(2_u32)
        expect(container.state_id).to eq(1_u32)
        expect(container.slots.size).to eq(90)
      end

      it "parses item slots with attribute_modifiers correctly" do
        io.read_byte # Skip packet ID (0x12)
        container = Rosegold::Clientbound::SetContainerContent.read(io)

        # Slot 2: item_id=939, 3 components (enchantments, attribute_modifiers, repair_cost)
        slot2 = container.slots[2]
        expect(slot2.slot_number).to eq(2_i16)
        slot = slot2.as(Rosegold::Slot)
        expect(slot.count).to eq(1_u32)
        expect(slot.item_id_int).to eq(939_u32)
        expect(slot.components_to_add.size).to eq(3)
        expect(slot.components_to_add.has_key?("enchantments")).to be_true
        expect(slot.components_to_add.has_key?("attribute_modifiers")).to be_true
        expect(slot.components_to_add.has_key?("repair_cost")).to be_true

        # Verify attribute modifiers parsed correctly
        attr_mod = slot.components_to_add["attribute_modifiers"].as(Rosegold::DataComponents::AttributeModifiers)
        expect(attr_mod.modifiers.size).to eq(2)
        expect(attr_mod.modifiers[0].modifier_id).to eq("finale:attack_speed")
        expect(attr_mod.modifiers[1].modifier_id).to eq("finale:attack_damage")
      end
    end
  end

  # Two-way serialization: parse the real fixture, re-encode it via write(), re-parse,
  # and verify structural round-trip. A write-side bug (wrong component body bytes,
  # missing field, misaligned count, etc.) would produce unparseable bytes or a
  # different post-re-parse structure.
  describe "two-way serialization" do
    describe "1.21.11 real production packet (many slots)" do
      before_each { Rosegold::Client.protocol_version = 774_u32 }
      after_each { Rosegold::Client.reset_protocol_version! }

      let(:fixture_1121_hex) { "" }

      it "round-trips through write() without losing structure" do
        bytes = Bytes.new(fixture_1121_hex.size // 2) { |i| fixture_1121_hex[i * 2, 2].to_u8(16) }

        io1 = Minecraft::IO::Memory.new(bytes)
        io1.read_byte
        original = Rosegold::Clientbound::SetContainerContent.read(io1)

        written_bytes = original.write
        io2 = Minecraft::IO::Memory.new(written_bytes)
        io2.read_byte
        roundtripped = Rosegold::Clientbound::SetContainerContent.read(io2)

        expect(roundtripped.window_id).to eq(original.window_id)
        expect(roundtripped.state_id).to eq(original.state_id)
        expect(roundtripped.slots.size).to eq(original.slots.size)

        original.slots.zip(roundtripped.slots).each do |original_slot, roundtripped_slot|
          orig_slot = original_slot.as(Rosegold::Slot)
          rt_slot = roundtripped_slot.as(Rosegold::Slot)
          expect(rt_slot.count).to eq(orig_slot.count)
          expect(rt_slot.item_id_int).to eq(orig_slot.item_id_int)
          expect(rt_slot.components_to_add.keys.sort!).to eq(orig_slot.components_to_add.keys.sort!)
          expect(rt_slot.components_to_remove.to_a.sort!).to eq(orig_slot.components_to_remove.to_a.sort!)
        end
      end

      # If this fails but the structural round-trip passes, our writer is producing
      # bytes that our own lenient parser accepts but vanilla rejects.
      it "produces byte-identical output through write()" do
        bytes = Bytes.new(fixture_1121_hex.size // 2) { |i| fixture_1121_hex[i * 2, 2].to_u8(16) }
        io1 = Minecraft::IO::Memory.new(bytes)
        io1.read_byte
        original = Rosegold::Clientbound::SetContainerContent.read(io1)

        written = original.write
        expect(written.hexstring).to eq(bytes.hexstring)
      end
    end

    # Structural round-trips for each existing 1.21.8 fixture. These catch writer
    # bugs that produce semantically wrong slots (missing fields, wrong codec, etc.)
    # without being brittle to NBT compound field reordering, which vanilla tolerates.
    describe "1.21.8 structural round-trips" do
      before_each { Rosegold::Client.protocol_version = 772_u32 }
      after_each { Rosegold::Client.reset_protocol_version! }

      macro assert_structural_roundtrip(name, hex)
        it "round-trips {{name.id}} structurally" do
          bytes = Bytes.new({{hex}}.size // 2) { |i| {{hex}}[i * 2, 2].to_u8(16) }
          io1 = Minecraft::IO::Memory.new(bytes)
          io1.read_byte # packet id
          original = Rosegold::Clientbound::SetContainerContent.read(io1)

          io2 = Minecraft::IO::Memory.new(original.write)
          io2.read_byte # packet id
          rt = Rosegold::Clientbound::SetContainerContent.read(io2)

          expect(rt.window_id).to eq(original.window_id)
          expect(rt.state_id).to eq(original.state_id)
          expect(rt.slots.size).to eq(original.slots.size)
          original.slots.zip(rt.slots).each do |orig, new_slot|
            o = orig.as(Rosegold::Slot)
            n = new_slot.as(Rosegold::Slot)
            expect(n.count).to eq(o.count)
            expect(n.item_id_int).to eq(o.item_id_int)
            expect(n.components_to_add.keys.sort).to eq(o.components_to_add.keys.sort)
            expect(n.components_to_remove.to_a.sort).to eq(o.components_to_remove.to_a.sort)
          end
        end
      end

      assert_structural_roundtrip "armor-is-bound-to (Godprot)",
        ""

      assert_structural_roundtrip "banner_patterns (63)",
        ""

      assert_structural_roundtrip "potion (42)",
        ""

      assert_structural_roundtrip "trim (47)",
        ""

      assert_structural_roundtrip "dyed_color (35)",
        ""
    end
  end
end
